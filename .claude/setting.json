{
  "$schema": "https://json-schema.org/claude-code-settings.json",
  "language": "korean",
  "permissions": {
    "allow": [
      "Bash(./gradlew build:*)",
      "Bash(./gradlew test:*)",
      "Bash(./gradlew bootRun:*)",
      "Bash(./gradlew clean:*)",
      "Bash(./gradlew checkstyleMain:*)",
      "Bash(git status)",
      "Bash(git diff:*)",
      "Bash(git log:*)",
      "Bash(git branch:*)",
      "Edit(*)",
      "Read(*)",
      "Write(*)"
    ],
    "deny": [
      "Bash(rm -rf:*)",
      "Bash(git push --force:*)",
      "Bash(git reset --hard:*)",
      "Bash(curl:*)"
    ]
  }
}